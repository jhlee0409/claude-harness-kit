# VHS tape for harness-kit's demo GIF. Render: bash docs/demo/build-demo.sh
# Shows a faithful Claude Code session running /harness-kit:introspect (the real
# trigger). The launch command is hidden; only the session is recorded.
Output demo.gif

Set Shell bash
Set FontSize 18
Set Width 1180
Set Height 700
Set Padding 22
Set Theme "Dracula"

Hide
Type "clear" Enter
Type "session" Enter
Show
Sleep 9s
